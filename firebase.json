{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "hosting": {
    "public": ".next",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "firebase/storage.rules"
  },
  "functions": [
    {
      "codebase": "default",
      "predeploy": [
        "pnpm --dir \"$RESOURCE_DIR\" run lint",
        "pnpm --dir \"$RESOURCE_DIR\" run build"
      ],
      "ignore": [
        "node_modules",
        "**/node_modules/**",
        "coverage",
        ".nyc_output",
        "test",
        "test_data",
        "generators",
        ".git",
        ".firebase",
        ".react-email",
        ".env",
        ".env.*",
        "*.log",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "source": "functions"
    }
  ],
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true
    },
    "pubsub": {
      "port": 8087
    },
    "singleProjectMode": true
  }
}
